include README.md
include LICENSE
include requirements.txt
include pyproject.toml

recursive-include mathviz *.py
recursive-include notebooks *.ipynb
recursive-include tests *.py

exclude .gitignore
exclude .env
exclude *.log
prune venv
prune .venv
prune __pycache__
prune .pytest_cache
prune *.egg-info
prune dist
prune build
prune htmlcov
prune .ipynb_checkpoints
