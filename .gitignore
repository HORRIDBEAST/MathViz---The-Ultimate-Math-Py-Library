# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-link
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# ── Distribution / packaging ──────────────────────────────────────────────────
*.tar.gz
*.whl

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
# Keep .ipynb source files but ignore checkpoint dirs and generated outputs
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Saved figure outputs (generated at runtime) ───────────────────────────────
*.png
*.jpg
*.jpeg
*.pdf
*.svg
# Exception: keep any images deliberately committed to docs/assets
!docs/assets/*.png
!docs/assets/*.svg

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs & temp files ─────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ── MyPy / type checking ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Secrets / environment variables ──────────────────────────────────────────
.env
.env.*
secrets.py

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
desktop.ini
